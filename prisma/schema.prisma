generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = env("DB_PROVIDER")
  url      = env("DATABASE_URL")
}

// Role: CUSTOMER | PROVIDER | ADMIN
// BookingStatus: PENDING | CONFIRMED | IN_PROGRESS | COMPLETED | CANCELLED | DISPUTED
// ProviderStatus: PENDING | APPROVED | REJECTED | SUSPENDED
// PaymentStatus: UNPAID | PAID | REFUNDED

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  role         String   @default("CUSTOMER")
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings     Booking[]      @relation("CustomerBookings")
  sentMessages Message[]      @relation("SentMessages")
  provider     Provider?
  tickets      SupportTicket[]

  @@map("users")
}

model Provider {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String   @default("PENDING")
  bio            String?
  trades         Trade[]
  serviceRadius  Int      @default(20)
  baseHourlyRate Float
  address        String?
  city           String
  latitude       Float?
  longitude      Float?
  rating         Float    @default(0)
  reviewCount    Int      @default(0)
  availability   Availability[]
  bookings       Booking[]      @relation("ProviderBookings")
  documents      Document[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("providers")
}

model Trade {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  icon      String?
  providers Provider[]
  bookings  Booking[]

  @@map("trades")
}

model Availability {
  id         String   @id @default(cuid())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)

  @@unique([providerId, dayOfWeek])
  @@map("availability")
}

model Booking {
  id            String   @id @default(cuid())
  customer      User     @relation("CustomerBookings", fields: [customerId], references: [id])
  customerId    String
  provider      Provider @relation("ProviderBookings", fields: [providerId], references: [id])
  providerId    String
  trade         Trade    @relation(fields: [tradeId], references: [id])
  tradeId       String
  status        String   @default("PENDING")
  paymentStatus String   @default("UNPAID")

  description   String
  answers       String   // stored as JSON string

  scheduledDate   DateTime
  scheduledTime   String
  durationHours   Float    @default(1)

  estimatedMin  Float
  estimatedMax  Float
  finalPrice    Float?

  address       String
  city          String
  latitude      Float?
  longitude     Float?

  stripePaymentIntentId String?
  jobPhotos             String?  // JSON array of photo URLs
  problemPhotos         String?  // JSON array of problem photo URLs (uploaded by customer)

  messages  Message[]
  review    Review?
  ticket    SupportTicket?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}

model Message {
  id        String    @id @default(cuid())
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String
  sender    User      @relation("SentMessages", fields: [senderId], references: [id])
  senderId  String
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("messages")
}

model Review {
  id        String   @id @default(cuid())
  booking   Booking  @relation(fields: [bookingId], references: [id])
  bookingId String   @unique
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@map("reviews")
}

model Document {
  id         String   @id @default(cuid())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  type       String
  url        String
  createdAt  DateTime @default(now())

  @@map("documents")
}

model SupportTicket {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?  @unique
  subject   String
  body      String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_tickets")
}
